<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
 "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "https://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">
<policyconfig>
  <vendor>Fedora Updater</vendor>
  <vendor_url>https://github.com/bquinlan/fedora-updater</vendor_url>

  <action id="me.blq.FedoraUpdater.upgrade">
    <description>Install system updates</description>
    <message>Authentication is required to install system updates</message>
    <icon_name>me.blq.FedoraUpdater</icon_name>
    <defaults>
      <allow_any>auth_admin</allow_any>
      <allow_inactive>auth_admin</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">@pkgdatadir@/upgrade_helper.py</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
  </action>

  <action id="me.blq.FedoraUpdater.system-upgrade">
    <description>Download and perform a Fedora system upgrade</description>
    <message>Authentication is required to download the system upgrade</message>
    <icon_name>me.blq.FedoraUpdater</icon_name>
    <defaults>
      <allow_any>auth_admin</allow_any>
      <allow_inactive>auth_admin</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">@pkgdatadir@/system_upgrade_helper.py</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
  </action>
</policyconfig>
